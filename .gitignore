*.egg
MANIFEST

# --- Virtual Environment ---
venv/
ENV/
env/
.venv/
.ENV/

# --- Environment Variables (IMPORTANT!) ---
.env
.env.local
.env.*.local
*.env

# --- Generated Reports (your blog outputs) ---
reports/
*.md
*.html

# --- Node.js / Frontend ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
.pnp
.pnp.js

# --- IDE / Editor ---
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
*.sublime-project

# --- OS Generated Files ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# --- Docker ---
.dockerignore

# --- Logs & Temp ---
*.log
*.tmp
*.temp
.cache/

# --- Misc ---
*.bak
*.swp
*.swo".env" 
