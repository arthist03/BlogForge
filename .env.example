# BlogForge Pro — Environment Variables
# Copy this to .env and fill in your keys

# At least one LLM key is required. Groq is free.
GROQ_API_KEY=gsk_your_key_here
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# DEEPSEEK_API_KEY=sk-...

# Comma-separated list of allowed frontend origins (CORS)
ALLOWED_ORIGINS=https://YOUR_USERNAME.github.io,http://localhost:3000

# Max generate requests per IP per hour
RATE_LIMIT_PER_HOUR=10
